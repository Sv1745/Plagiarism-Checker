[Unit]
Description=Plagiarism Checker Backend (FastAPI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/plagiarism-checker/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/plagiarism-checker/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
