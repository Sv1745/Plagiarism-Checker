[Unit]
Description=Plagiarism Checker Backend (FastAPI)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/plagiarism-checker/backend
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/plagiarism-checker/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
